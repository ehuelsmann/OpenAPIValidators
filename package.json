{
  "private": true,
  "name": "openapi-validators",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "clean": "yarn workspaces run clean && rimraf packages/.nyc_output && rimraf packages/coverage",
    "format": "prettier --write . --ignore-path .prettierignore",
    "lint": "yarn workspaces run lint",
    "build": "yarn workspaces run build",
    "test": "yarn workspaces run test",
    "test:ci": "yarn workspaces run test:ci",
    "version:bump": "node scripts/bump-version.mjs"
  },
  "resolutions": {
    "openapi-types": "12.1.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "eslint": "^7.11.0",
    "eslint-config-airbnb-base": "^14.2.1",
    "eslint-config-airbnb-typescript": "^14.0.1",
    "eslint-config-prettier": "^6.12.0",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-jest": "^27.9.0",
    "eslint-plugin-mocha": "^8.0.0",
    "express": "^5.2.1",
    "husky": "^4.3.0",
    "prettier": "^3.8.2",
    "rimraf": "^3.0.2",
    "typescript": "^5.0.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "yarn test:ci"
    }
  },
  "packageManager": "yarn@4.13.0+sha512.5c20ba010c99815433e5c8453112165e673f1c7948d8d2b267f4b5e52097538658388ebc9f9580656d9b75c5cc996f990f611f99304a2197d4c56d21eea370e7"
}
