{
  "name": "@ehuelsmann/openapi-validator",
  "version": "0.15.0",
  "description": "Common code for jest-openapi and Chai OpenAPI Response Validator",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "format": "prettier --write . --ignore-path ../../.prettierignore",
    "lint": "tsc --noEmit && eslint .",
    "lint:fix": "yarn lint --fix",
    "build": "tsup",
    "test": "echo",
    "test:ci": "echo",
    "prepack": "yarn build"
  },
  "repository": "https://github.com/ehuelsmann/OpenAPIValidators/tree/master/packages/openapi-validator",
  "author": "OpenApiChai <openapichai@gmail.com>",
  "contributors": [
    "rwalle61 <richard.lh.waller@gmail.com>",
    "Jonny Spruce <jspruce94@gmail.com>"
  ],
  "license": "MIT",
  "keywords": [
    "jest",
    "chai",
    "openapi",
    "testing",
    "response",
    "validate"
  ],
  "bugs": {
    "url": "https://github.com/ehuelsmann/OpenAPIValidators/issues"
  },
  "homepage": "https://github.com/ehuelsmann/OpenAPIValidators#openapi-validators",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@types/superagent": "^4.1.12",
    "axios": "^1.15.0",
    "combos": "^0.2.0",
    "fs-extra": "^9.0.0",
    "js-yaml": "^4.0.0",
    "openapi-response-validator": "^12.1.3",
    "openapi-schema-validator": "^9.2.0",
    "path-parser": "^6.1.0",
    "typeof": "^1.0.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^9.0.12",
    "@types/js-yaml": "^4.0.3",
    "@types/typeof": "^1.0.0",
    "openapi-types": "^12.1.3",
    "tsup": "^8.5.1"
  }
}
